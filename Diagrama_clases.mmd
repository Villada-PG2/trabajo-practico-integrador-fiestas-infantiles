classDiagram
 
    Reserva -->"1" Cliente
    SistemaAdministracion -->"0..*" Reserva
    Cliente --|> Persona
    Cliente -->"1..*" Chico
    Reserva "1"<--FiestaInfantil
    Reserva -->"1..*" CambioEstadoReserva
    CambioEstadoReserva -->"1" EstadoReserva
    FiestaInfantil -->"1..*" Chico
    FiestaInfantil "0..*"<-- Coordinadora
    FiestaInfantil -->"1..*" JuegoParque
    Coordinadora --|> Persona
    Reserva -->"1" Carpa
    Persona -->"1" TipoDocumento
    Chico --|> Persona
    Reserva -->"1" PaqueteReserva

    class Reserva {
        -Cliente cliente
        -Chico cumpleañero
        -Date diaCumpleaños
        -Str nombreCliente
        -Str apellidoCliente
        -Str numeroTelefonoCliente
        -Int DocumentoCliente
        -TipoDocumento tipoDocumentoCliente
        -Str nombreCumpleañero
        -Str apellidoCumpleañero
        -Str edadCumpleañero
        -Int DocumentoCumpleañero
        -TipoDocumento tipoDocumentoCumpleañero
        -Int cantidadInvitados
        -Time HoraCumpleaños
        -PaqueteReserva paqueteReserva
        -Carpa CarpaSeleccionada
        -Str datosAdicionales
        -EstadoPago estadoPagoReserva
        -CambioEstado[list] listaCambiosEstado
        -Time tiempoValidez
        -getDocumentoCliente()
        -getDocumentoCumpleañero()
        -CalcularTotal()
        -carpaDisonible()
        -horarioDisponible()
        +setReservaCreada()
        -ocuparHorario()
        +setPendienteConfirmacion()
        +pasoTiempoValidez()
        +setAnulada()
        +setCancelada()
        -CalcularLapsoHastaReserva()
        -CalcularTotalARetener()
    }
    class Cliente {
        -Str numeroTelefono
        -Chico[list] hijos

        +getDocumentoCliente()
        +getDocumentoCumpleañero()
    }
    class Persona {
        -Str nombre
        -Str apellido
        -Str docmuneto
        -TipoDocumento tipoDocumento
    }
    class Carpa{
        -Int numero
        -Horario[list] horariosCarpa
        +getHorariosDisponibles()
    }

    class CambioEstadoReserva {
        -DateTime fechaHoraInicio
        -DateTime fechaHoraFin
        -EstadoReserva estado
        +setCreada()
        +setPendienteConfirmacion()
        +pasoTiempoValidez()
        +setConfirmada()
        +setAnulada()
        +setCancelada()
    }

    class EstadoReserva {
        -Str nombre
        -Str descripcion
        +esCreada()
        +esPendienteConfirmacion()
        +esConfirmada()
        +esAnulada()
        +esCancelada()
    }
    class PaqueteReserva {
        -Str nombre
        -Str descripcion
        -Float precioPaquete
    }
    class TipoDocumento {
        -Str nombre
        -Str descripcion
    }
    class FiestaInfantil {
        -Chico[list] listaChicosDeFiesta
        -Coordinadora coordinadoraAsignada
        -JuegoParque[list] juegosDisponibles
        -getJuegosAcordeAEdad()
    }
    class Chico {
        -Int edad
        +esCumpleañero()
        +getDocumentoCumpleañero()
    }
    class SistemaAdministracion["SistemaAdministracion / RAP"] {
        -Reserva[list] listaReservas
        -crearReserva()
        -setPendienteConfirmacion()
        -pasoTiempoValidez()
        -ConfirmarReserva()
        -AnularReserva()
        -CancelarReserva()
    }

    class Coordinadora{
        -anotarNombreYApellidoDeCadaNiño()
        -totalizarCantidadDeNiños()
        -calcularNiñosExtra()
    }

    class JuegoParque {
        -Str nombre
        -Str descripcion
        -Int edadMinima
        +esAcordeAEdad()
        +getDatosJuego()
    }