classDiagram

    Reserva -->"1" Cliente
    SistemaAdministracion -->"0..*" Reserva
    Administrador -->"1" SistemaAdministracion
    Cliente --|> Persona
    Cliente -->"1..*" Chico
    Reserva "1"<--FiestaInfantil
    Reserva -->"1" EstadoPago
    FiestaInfantil -->"1..*" Chico
    Reserva -->"1" Carpa
    Persona -->"1" TipoDocumento
    Chico --|> Persona
    Reserva -->"1" PaqueteReserva
    Reserva -->"1" FormaPago
    class Reserva {
        -Date diaCumpleaños
        -Str nombreCliente
        -Str apellidoCliente
        -Str numeroTelefonoCliente
        -Int DocumentoCliente
        -TipoDocumento tipoDocumentoCliente
        -Str nombreCumpleañero
        -Str apellidoCumpleañero
        -Str edadCumpleañero
        -Int DocumentoCumpleañero
        -TipoDocumento tipoDocumentoCumpleañero
        -Int cantidadInvitados
        -Time HoraCumpleaños
        -PaqueteReserva paqueteReserva
        -Carpa CarpaSeleccionada
        -Str datosAdicionales
        -FormaPago formaPagoReserva
        -EstadoPago estadoPagoReserva
        -getDocumentoCliente()
        -getDocumentoCumpleañero()
        -CalcularTotal()
    }
    class Cliente {
        -Str numeroTelefono
        +getDocumentoCliente()
        +getDocumentoCumpleañero()
    }
    class Persona {
        -Str nombre
        -Str apellido
        -Str docmuneto
        -TipoDocumento tipoDocumento
    }
    class Carpa{
        -Int numero
    }
    class Administrador
    class EstadoPago {
        -Str nombre
        -Str descripcion
    }
    class PaqueteReserva {
        -Str nombre
        -Str descripcion
        -Float precioPaquete
    }
    class TipoDocumento {
        -Str nombre
        -Str descripcion
    }
    class FiestaInfantil {
        -Chico[list] listaChicosDeFiesta
    }
    class Chico {
        -Int edad
        +esCumpleañero()
        +getDocumentoCumpleañero()
    }
    class SistemaAdministracion 
    class FormaPago {
        -Str nombre
        -Str descripcion
    }
